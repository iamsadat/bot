# Copy to `.env` (in the repo root) and fill in.
# The app reads .env on startup via pydantic-settings.

# ---------- Alpaca PAPER (free, recommended for the first 30+ days) ----
# Get keys at: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_PAPER_KEY=PKxxxxxxxxxxxxxxxxxx
ALPACA_PAPER_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------- Alpaca LIVE (real money — DO NOT FILL UNTIL PAPER IS PROVEN) -
# Leave blank until you are ready to go live.  Setting these alone does
# *not* enable live trading — you must also POST /api/safety/mode with the
# confirmation phrase below.
# ALPACA_LIVE_KEY=
# ALPACA_LIVE_SECRET=

# ---------- Server -----------------------------------------------------
HOST=127.0.0.1
PORT=8000

# ---------- Risk rails (server-enforced) -------------------------------
RISK_PER_TRADE=0.0075
MAX_POSITION_NOTIONAL_PCT=0.25
DAILY_LOSS_LIMIT_PCT=0.025
MAX_ORDERS_PER_MINUTE=10
STOP_ATR_MULT=1.5
RR_RATIO=2.0

# Engine cadence
ENGINE_TICK_SECONDS=60

# Phrase the UI must send to switch into live trading.
LIVE_CONFIRMATION_PHRASE=I_UNDERSTAND_REAL_MONEY
