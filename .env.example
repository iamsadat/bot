# Copy to .env and fill in as needed. None of these are required to run the
# offline test suite or the demo with fixture data.

# SQLite path for the legacy single-tenant dev server (ignored in multi-tenant mode).
JOBHUNT_DB_PATH=jobhunt.db

# Multi-tenant mode (used by the deployed app): where per-workspace SQLite files live,
# and the max number of concurrent workspaces kept warm in memory.
JOBHUNT_WORKSPACES_DIR=workspaces
JOBHUNT_WORKSPACE_CAP=200

# Optional shared passcode testers must enter once before driving the live pipeline.
# Leave unset to keep the app open.
JOBHUNT_ACCESS_CODE=

# Optional: real Postgres instead of SQLite (see jobhunt/db/engine.py).
DATABASE_URL=

# Optional: enables real LLM-backed bullet tone-polish instead of plain heuristics.
# Gemini has a free tier (get a key at https://aistudio.google.com/apikey) — checked
# first, so it's the $0 option for solo testing. Anthropic is the paid fallback.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: recruiter-email auto-status. When these are set (single-tenant
# `python -m jobhunt serve`), the app polls your inbox and auto-advances
# matched applications (interview/assessment/offer/rejection) + surfaces
# Calendly/Zoom interview times. For Gmail, use an App Password, not your
# login password. Left unset = feature off.
JOBHUNT_IMAP_HOST=
JOBHUNT_IMAP_USER=
JOBHUNT_IMAP_PASSWORD=
JOBHUNT_IMAP_MAILBOX=INBOX
JOBHUNT_IMAP_POLL_SECONDS=300

# Optional: continuous discovery + fully-autonomous auto-apply (single-tenant
# `python -m jobhunt serve`). DISCOVERY_POLL_SECONDS=0 (default) disables the
# background sweep; set e.g. 900 to re-discover every 15 min and MERGE new jobs
# (never clears). AUTO_APPLY=1 + a connected real ATS auto-submits matches at or
# above the relevance floor, up to DAILY_APPLY_CAP per day. Fixtures never POST.
JOBHUNT_DISCOVERY_POLL_SECONDS=0
JOBHUNT_AUTO_APPLY=
JOBHUNT_DAILY_APPLY_CAP=20
# Tailoring volume + selectivity knobs (used by every run).
JOBHUNT_SHORTLIST_CAP=10
JOBHUNT_VETTING_THRESHOLD=
