# Copy to .env and fill in as needed. None of these are required to run the
# offline test suite or the demo with fixture data.

# SQLite path for the legacy single-tenant dev server (ignored in multi-tenant mode).
JOBHUNT_DB_PATH=jobhunt.db

# Multi-tenant mode (used by the deployed app): where per-workspace SQLite files live,
# and the max number of concurrent workspaces kept warm in memory.
JOBHUNT_WORKSPACES_DIR=workspaces
JOBHUNT_WORKSPACE_CAP=200

# Optional shared passcode testers must enter once before driving the live pipeline.
# Leave unset to keep the app open.
JOBHUNT_ACCESS_CODE=

# Optional: real Postgres instead of SQLite (see jobhunt/db/engine.py).
DATABASE_URL=

# Optional: enables real LLM-backed bullet tone-polish instead of plain heuristics.
# Gemini has a free tier (get a key at https://aistudio.google.com/apikey) — checked
# first, so it's the $0 option for solo testing. Anthropic is the paid fallback.
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: recruiter-email auto-status. When these are set (single-tenant
# `python -m jobhunt serve`), the app polls your inbox and auto-advances
# matched applications (interview/assessment/offer/rejection) + surfaces
# Calendly/Zoom interview times. For Gmail, use an App Password, not your
# login password. Left unset = feature off.
JOBHUNT_IMAP_HOST=
JOBHUNT_IMAP_USER=
JOBHUNT_IMAP_PASSWORD=
JOBHUNT_IMAP_MAILBOX=INBOX
JOBHUNT_IMAP_POLL_SECONDS=300

# Optional: continuous discovery + fully-autonomous auto-apply (single-tenant
# `python -m jobhunt serve`). DISCOVERY_POLL_SECONDS=0 (default) disables the
# background sweep; set e.g. 900 to re-discover every 15 min and MERGE new jobs
# (never clears). AUTO_APPLY=1 + a connected real ATS auto-submits matches at or
# above the relevance floor, up to DAILY_APPLY_CAP per day. Fixtures never POST.
JOBHUNT_DISCOVERY_POLL_SECONDS=0
JOBHUNT_AUTO_APPLY=
JOBHUNT_DAILY_APPLY_CAP=20
# Tailoring volume + selectivity knobs (used by every run).
JOBHUNT_SHORTLIST_CAP=10
JOBHUNT_VETTING_THRESHOLD=

# Optional aggregator job sources (native keyword/location search). These
# augment whatever ATS boards you connect. Recruitee/Workable/Personio are
# keyless and configured as company slugs in the dashboard (ATS settings).
# Adzuna: free key at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=us
# USAJobs (US federal): free key at https://developer.usajobs.gov/ — email is
# the one you registered; sent as the User-Agent per their API rules.
USAJOBS_EMAIL=
USAJOBS_API_KEY=

# Optional outbound notifications. Any subset enables the feature; events
# (new matches, auto-applied, interview/assessment from email) fan out to all
# configured channels. The generic webhook (Zapier/n8n/Make) posts the full
# structured event so you can route on `kind`. Test with POST /api/notify/test.
JOBHUNT_SLACK_WEBHOOK=
JOBHUNT_DISCORD_WEBHOOK=
JOBHUNT_TELEGRAM_BOT_TOKEN=
JOBHUNT_TELEGRAM_CHAT_ID=
JOBHUNT_WEBHOOK_URLS=
# Optional email notifications (SMTP).
JOBHUNT_SMTP_HOST=
JOBHUNT_SMTP_PORT=587
JOBHUNT_SMTP_USER=
JOBHUNT_SMTP_PASSWORD=
JOBHUNT_NOTIFY_EMAIL=

# Optional Google integration (OAuth): Gmail (recruiter-email auto-status —
# preferred over IMAP when set — plus sending follow-ups/thank-yous) and Google
# Calendar (interview holds). Create an OAuth client + obtain a refresh token
# with gmail.modify, gmail.send, calendar.events scopes.
JOBHUNT_GOOGLE_CLIENT_ID=
JOBHUNT_GOOGLE_CLIENT_SECRET=
JOBHUNT_GOOGLE_REFRESH_TOKEN=
JOBHUNT_GOOGLE_USER=me

# Optional recruiter-contact enrichment for outreach. Hunter.io free tier:
# https://hunter.io/api-keys (Apollo / People Data Labs can plug in later).
JOBHUNT_HUNTER_API_KEY=

# Optional company news intel (salary intel reuses the ADZUNA_* keys above).
# NewsAPI free tier: https://newsapi.org/register
JOBHUNT_NEWSAPI_KEY=

# Optional real-browser autofill for career pages with no apply API
# (Workday/iCIMS/generic). Needs Playwright (`pip install playwright &&
# playwright install chromium`). Off by default; co-pilot mode fills the form
# and leaves the final submit to you. Set =1 to enable POST /api/autofill.
JOBHUNT_AUTOFILL_ENABLED=
JOBHUNT_AUTOFILL_HEADLESS=1
# Optional explicit chromium binary (when browsers are pre-provisioned).
PLAYWRIGHT_CHROMIUM_EXECUTABLE=
