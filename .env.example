# Copy to .env and fill in as needed. None of these are required to run the
# offline test suite or the demo with fixture data.

# SQLite path for the legacy single-tenant dev server (ignored in multi-tenant mode).
JOBHUNT_DB_PATH=jobhunt.db

# Multi-tenant mode (used by the deployed app): where per-workspace SQLite files live,
# and the max number of concurrent workspaces kept warm in memory.
JOBHUNT_WORKSPACES_DIR=workspaces
JOBHUNT_WORKSPACE_CAP=200

# Optional shared passcode testers must enter once before driving the live pipeline.
# Leave unset to keep the app open.
JOBHUNT_ACCESS_CODE=

# Optional: real Postgres instead of SQLite (see jobhunt/db/engine.py).
DATABASE_URL=

# Optional: enables real LLM-backed resume tailoring/critique instead of heuristics.
ANTHROPIC_API_KEY=
